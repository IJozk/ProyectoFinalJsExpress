<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-5">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">KanbanPro</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link {{#ifEquals ruta '/'}}active fw-bold border-bottom border-primary{{/ifEquals}}" href="/">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{#ifEquals ruta '/about'}}active fw-bold border-bottom border-primary{{/ifEquals}}" href="/about">Acerca de</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{#ifEquals ruta '/contactanos'}}active fw-bold border-bottom border-primary{{/ifEquals}}" href="/contactanos">Contacto</a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    {{#if user}}
                    <li class="nav-item dropdown">
                        <button class="btn-user-menu" data-bs-toggle="dropdown" aria-expanded="false">
                            {{user.userName}}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end mk-dropdown">
                            <li><a class="mk-dropdown__item" href="/profile">Ver perfil</a></li>
                            <li><hr class="mk-dropdown__divider"></li>
                            <li>
                                <form action="/logout" method="post">
                                    <button type="submit" class="mk-dropdown__item mk-dropdown__item--danger">Cerrar sesión</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                    {{else}}
                    <li class="nav-item">
                        <a class="btn btn-outline-primary me-2" href="/login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary" href="/register">Register</a>
                    </li>
                    {{/if}}
                </ul>
            </div>
        </div>
    </nav>

    <h1 class="ms-5">{{titulo}}</h1>

</header>