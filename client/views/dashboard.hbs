<div class="container py-4">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 style="font-size:1.25rem; font-weight:700; margin:0">{{ user.userName }}</h1>
        <button class="btn-add" style="width:auto" data-toggle-target="#newBoardForm">+ Tablero</button>
    </div>

    <div id="newBoardForm" class="collapse mb-4" style="max-width:320px">
        <form action="/createBoard" method="post" class="d-flex flex-column gap-2">
            <input type="text" class="form-control form-control-sm" name="title" placeholder="Nombre del tablero" required>
            <textarea class="form-control form-control-sm" name="description" placeholder="Descripción" rows="2"></textarea>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">Crear</button>
                <button type="button" class="btn btn-secondary btn-sm" data-toggle-target="#newBoardForm" data-toggle-action="hide">Cancelar</button>
            </div>
        </form>
    </div>

    {{#each tableros}}
    <div class="mb-5">

        <div class="board-header">
            <button class="btn-add" style="width:auto; font-size:1rem; font-weight:700; color:#172b4d" data-toggle-target="#boardToggle{{id}}">
                {{title}}
            </button>
            <button class="btn-add" style="width:auto"
                    data-toggle-target="#newListForm{{id}}">+ Lista</button>
        </div>

        <div id="newListForm{{id}}" class="collapse mb-3" style="max-width:320px">
            <form action="/createList" method="post" class="d-flex flex-column gap-2">
                <input type="text" class="form-control form-control-sm" name="title" placeholder="Nombre de la lista" required>
                <input type="hidden" name="boardId" value="{{id}}">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm">Crear</button>
                    <button type="button" class="btn btn-secondary btn-sm" data-toggle-target="#newListForm{{id}}" data-toggle-action="hide">Cancelar</button>
                </div>
            </form>
        </div>

        <div id="boardToggle{{id}}" class="collapse show">
            <div class="d-flex gap-3 overflow-auto pb-2">
                {{#each Lists}}
                <div class="kanban-col" data-list-id="{{id}}">

                    <div class="kanban-col__header">
                        <span class="kanban-col__title">{{title}}</span>
                        <button class="btn-icon btn-icon--delete"
                                onclick="deleteList('{{id}}')"
                                title="Eliminar lista">✕</button>
                    </div>

                    <div class="kanban-col__cards">
                        {{#each Cards}}
                            {{> card lists=../../Lists}}
                        {{/each}}
                    </div>

                    <button class="btn-add"
                            data-bs-toggle="modal"
                            data-bs-target="#newCardModal"
                            data-list-id="{{id}}"
                            data-board-id="{{../id}}">+ Añadir tarea</button>
                </div>
                {{/each}}
            </div>
        </div>

    </div>
    {{/each}}

</div>
